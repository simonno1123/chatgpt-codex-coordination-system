#!/usr/bin/env python3
"""ACOS pre-commit hook.

Runs scripts/acos-linter.py against staged ACOS artifact markdown files.
This hook is deterministic and uses only local Git state plus Python stdlib.
"""

from __future__ import annotations

import os
from pathlib import Path
import subprocess
import sys
import tempfile

ARTIFACT_PREFIXES = (
    ".codex-coordination/inbox/",
    ".codex-coordination/outbox/",
    ".codex-coordination/decisions/",
    ".codex-coordination/templates/",
)


def run_git(args: list[str], cwd: Path) -> bytes:
    return subprocess.check_output(["git", *args], cwd=str(cwd))


def is_artifact(path: str) -> bool:
    return path.endswith(".md") and path.startswith(ARTIFACT_PREFIXES)


def main() -> int:
    repo_root = Path(run_git(["rev-parse", "--show-toplevel"], Path.cwd()).decode().strip())
    linter = repo_root / "scripts" / "acos-linter.py"
    if not linter.is_file():
        print("ACOS pre-commit: missing scripts/acos-linter.py", file=sys.stderr)
        return 1

    raw = run_git(["diff", "--cached", "--name-only", "--diff-filter=ACMR", "-z"], repo_root)
    staged_files = [item.decode() for item in raw.split(b"\0") if item]
    artifact_files = [path for path in staged_files if is_artifact(path)]

    if not artifact_files:
        return 0

    print("ACOS pre-commit: linting staged artifacts")
    failed = False
    with tempfile.TemporaryDirectory(prefix="acos-pre-commit-") as tmp:
        tmp_root = Path(tmp)
        for artifact_path in artifact_files:
            staged_copy = tmp_root / artifact_path
            staged_copy.parent.mkdir(parents=True, exist_ok=True)
            try:
                content = run_git(["show", f":{artifact_path}"], repo_root)
            except subprocess.CalledProcessError as exc:
                print(f"ACOS pre-commit: cannot read staged artifact {artifact_path}: {exc}", file=sys.stderr)
                failed = True
                continue
            staged_copy.write_bytes(content)

            print(f"ACOS pre-commit: {artifact_path}")
            result = subprocess.run(
                [sys.executable, str(linter), "--changed-path", artifact_path, str(staged_copy)],
                cwd=str(repo_root),
                check=False,
            )
            if result.returncode != 0:
                failed = True

    if failed:
        print("ACOS pre-commit: BLOCKED by artifact lint failure", file=sys.stderr)
        return 1

    print("ACOS pre-commit: PASS")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
