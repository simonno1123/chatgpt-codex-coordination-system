{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "urn:acos:schema:artifact-envelope:1.0",
  "title": "ACOS Artifact Envelope Schema",
  "type": "object",
  "properties": {
    "artifact_id": {
      "type": "string",
      "pattern": "^ART-[A-Za-z0-9][A-Za-z0-9._-]{2,127}$"
    },
    "artifact_type": {
      "type": "string",
      "enum": [
        "USER DECISION",
        "TASK",
        "RESULT",
        "BLOCKED RESULT",
        "REVIEW",
        "ADVISORY REQUEST",
        "ADVISORY REVIEW",
        "DECISION",
        "AUTHORIZATION",
        "AUDIT EVENT",
        "EXECUTION RECEIPT",
        "ERROR/BLOCKER RECORD"
      ]
    },
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+(?:\\.[0-9]+)?$"
    },
    "producer": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "producer_role": {
      "type": "string",
      "enum": [
        "user_decision_source",
        "chatgpt_review",
        "codex_executor",
        "external_advisory",
        "automation"
      ]
    },
    "producer_runtime_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+){1,15}$",
      "maxLength": 128
    },
    "project_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1024
    },
    "task_id": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 128
    },
    "workflow_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "parent_artifact_id": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 132
    },
    "correlation_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "expires_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "sequence": {
      "type": "integer",
      "minimum": 0
    },
    "scope": {
      "type": "array",
      "minItems": 1,
      "maxItems": 256,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 1024
      }
    },
    "requested_action": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 128
    },
    "authority_type": {
      "type": "string",
      "enum": [
        "user",
        "review",
        "commit",
        "push",
        "release",
        "exception",
        "none"
      ]
    },
    "authorization_id": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 128
    },
    "policy_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+(?:\\.[0-9]+)?$"
    },
    "content_digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "signature": {
      "type": "string",
      "pattern": "^sig:[A-Za-z0-9_-]{16,512}$"
    },
    "nonce": {
      "type": "string",
      "pattern": "^nonce:[A-Za-z0-9_-]{16,128}$"
    },
    "replay_protection": {
      "type": "object",
      "properties": {
        "class": {
          "type": "string",
          "enum": [
            "one_time",
            "reusable"
          ]
        },
        "max_consumption": {
          "type": "integer",
          "minimum": 1
        }
      },
      "required": [
        "class"
      ],
      "allOf": [
        {
          "if": {
            "properties": {
              "class": {
                "const": "one_time"
              }
            }
          },
          "then": {
            "required": [
              "max_consumption"
            ],
            "properties": {
              "max_consumption": {
                "const": 1
              }
            }
          }
        }
      ],
      "additionalProperties": false
    },
    "to": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "next_receiver": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "pending",
        "accepted",
        "denied",
        "blocked",
        "revoked",
        "superseded",
        "consumed",
        "completed"
      ]
    },
    "payload": {
      "type": "object",
      "maxProperties": 128
    }
  },
  "required": [
    "artifact_id",
    "artifact_type",
    "schema_version",
    "producer",
    "producer_role",
    "producer_runtime_id",
    "project_id",
    "workflow_id",
    "correlation_id",
    "created_at",
    "sequence",
    "scope",
    "authority_type",
    "policy_version",
    "content_digest",
    "signature",
    "nonce",
    "replay_protection",
    "to",
    "next_receiver",
    "status",
    "payload"
  ],
  "allOf": [
    {
      "if": {
        "properties": {
          "artifact_type": {
            "const": "USER DECISION"
          }
        }
      },
      "then": {
        "required": [
          "requested_action",
          "authorization_id",
          "expires_at"
        ],
        "properties": {
          "producer_role": {
            "const": "user_decision_source"
          },
          "authority_type": {
            "const": "user"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "artifact_type": {
            "enum": [
              "TASK",
              "REVIEW",
              "ADVISORY REQUEST",
              "DECISION",
              "AUTHORIZATION"
            ]
          }
        }
      },
      "then": {
        "properties": {
          "producer_role": {
            "const": "chatgpt_review"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "artifact_type": {
            "const": "ADVISORY REVIEW"
          }
        }
      },
      "then": {
        "properties": {
          "producer_role": {
            "const": "external_advisory"
          },
          "authority_type": {
            "const": "none"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "artifact_type": {
            "const": "AUDIT EVENT"
          }
        }
      },
      "then": {
        "properties": {
          "producer_role": {
            "const": "automation"
          },
          "authority_type": {
            "const": "none"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "artifact_type": {
            "enum": [
              "RESULT",
              "BLOCKED RESULT",
              "EXECUTION RECEIPT",
              "ERROR/BLOCKER RECORD"
            ]
          }
        }
      },
      "then": {
        "properties": {
          "producer_role": {
            "enum": [
              "codex_executor",
              "automation"
            ]
          },
          "authority_type": {
            "const": "none"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "artifact_type": {
            "enum": [
              "TASK",
              "RESULT",
              "BLOCKED RESULT",
              "REVIEW",
              "ADVISORY REQUEST",
              "ADVISORY REVIEW",
              "DECISION",
              "AUTHORIZATION",
              "EXECUTION RECEIPT",
              "ERROR/BLOCKER RECORD"
            ]
          }
        }
      },
      "then": {
        "required": [
          "task_id"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "artifact_type": {
            "const": "AUTHORIZATION"
          }
        }
      },
      "then": {
        "required": [
          "requested_action",
          "authorization_id",
          "expires_at"
        ],
        "properties": {
          "replay_protection": {
            "properties": {
              "class": {
                "const": "one_time"
              },
              "max_consumption": {
                "const": 1
              }
            }
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
