# Default text handling
* text=auto

# Markdown and text files
*.md text eol=lf
*.txt text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.ini text eol=lf
*.cfg text eol=lf

# Scripts
*.sh text eol=lf
*.py text eol=lf
*.js text eol=lf
*.ts text eol=lf

# Windows scripts
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.docx binary
*.xlsx binary
*.pptx binary
*.zip binary
*.7z binary
*.rar binary
*.pcap binary
*.pcapng binary
*.db binary
*.sqlite binary
*.sqlite3 binary
